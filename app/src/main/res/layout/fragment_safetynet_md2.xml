<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <import type="android.os.Build" />
        <import type="com.topjohnwu.magisk.core.Info" />
        <import type="com.topjohnwu.magisk.BuildConfig" />
        <import type="com.topjohnwu.magisk.R" />

        <variable
            name="viewModel"
            type="com.topjohnwu.magisk.ui.safetynet.SafetynetViewModel" />

    </data>


    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingTop="@dimen/internal_action_bar_size"
        app:fitsSystemWindowsInsets="top|bottom"
        tools:paddingBottom="48dp"
        tools:paddingTop="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="@dimen/l2">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:text="YASNAC"
                android:textAppearance="@style/AppearanceFoundation.Title"
                android:textStyle="bold"
                android:layout_marginTop="@dimen/l1" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:text="Yet Another SafetyNet Attestation Checker"
                android:textAppearance="@style/AppearanceFoundation.Body"
                android:layout_marginBottom="@dimen/l3" />

            <!-- Device Info Card -->
            <com.google.android.material.card.MaterialCardView
                style="@style/WidgetFoundation.Card.Elevated"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="@dimen/l1"
                app:cardElevation="@dimen/l1"
                android:layout_marginBottom="@dimen/l2">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/l2">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Device"
                        android:textAppearance="@style/AppearanceFoundation.Title"
                        android:layout_marginBottom="@dimen/l2" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Model"
                        android:textSize="12sp"
                        android:textColor="?android:textColorSecondary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@{viewModel.deviceModel}"
                        android:textAppearance="@style/AppearanceFoundation.Body"
                        android:layout_marginBottom="@dimen/l1"
                        tools:text="unknown (layoutlib)" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Android version"
                        android:textSize="12sp"
                        android:textColor="?android:textColorSecondary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@{viewModel.androidVersion}"
                        android:textAppearance="@style/AppearanceFoundation.Body"
                        android:layout_marginBottom="@dimen/l1"
                        tools:text="12 (API 31)" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Security patch level"
                        android:textSize="12sp"
                        android:textColor="?android:textColorSecondary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@{viewModel.securityPatch}"
                        android:textAppearance="@style/AppearanceFoundation.Body"
                        tools:text="2021-11-05" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Loading Indicator -->
            <TextView
                app:goneUnless="@{viewModel.checking}"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="@string/safetynet_attest_loading"
                android:textAppearance="@style/AppearanceFoundation.Title"
                android:layout_margin="@dimen/l3" />

            <!-- Result Card -->
            <com.google.android.material.card.MaterialCardView
                app:goneUnless="@{viewModel.hasResult &amp;&amp; !viewModel.checking}"
                style="@style/WidgetFoundation.Card.Elevated"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="@dimen/l1"
                app:cardElevation="@dimen/l1"
                android:layout_marginBottom="@dimen/l3">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/l2">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Result"
                        android:textAppearance="@style/AppearanceFoundation.Title"
                        android:layout_marginBottom="@dimen/l2" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Basic integrity"
                        android:textSize="12sp"
                        android:textColor="?android:textColorSecondary" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="@dimen/l1">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@{viewModel.basicIntegrityState ? `Pass` : `Fail`}"
                            app:textColorAttr="@{viewModel.basicIntegrityState ? R.attr.colorPrimary : R.attr.colorError}"
                            android:textAppearance="@style/AppearanceFoundation.Body"
                            tools:text="Pass" />
                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_marginStart="4dp"
                            app:srcCompat="@{viewModel.basicIntegrityState ? @drawable/ic_check_circle_md2 : @drawable/ic_close_md2}"
                            app:tintAttr="@{viewModel.basicIntegrityState ? R.attr.colorPrimary : R.attr.colorError}"
                            tools:src="@drawable/ic_check_circle_md2"
                            tools:tint="?colorPrimary" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CTS profile match"
                        android:textSize="12sp"
                        android:textColor="?android:textColorSecondary" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="@dimen/l1">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@{viewModel.ctsState ? `Pass` : `Fail`}"
                            app:textColorAttr="@{viewModel.ctsState ? R.attr.colorPrimary : R.attr.colorError}"
                            android:textAppearance="@style/AppearanceFoundation.Body"
                            tools:text="Pass" />
                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_marginStart="4dp"
                            app:srcCompat="@{viewModel.ctsState ? @drawable/ic_check_circle_md2 : @drawable/ic_close_md2}"
                            app:tintAttr="@{viewModel.ctsState ? R.attr.colorPrimary : R.attr.colorError}"
                            tools:src="@drawable/ic_check_circle_md2"
                            tools:tint="?colorPrimary" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Evaluation type"
                        android:textSize="12sp"
                        android:textColor="?android:textColorSecondary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@{viewModel.evalType}"
                        android:textAppearance="@style/AppearanceFoundation.Body"
                        android:layout_marginBottom="@dimen/l1"
                        tools:text="HARDWARE_BACKED" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Timestamp"
                        android:textSize="12sp"
                        android:textColor="?android:textColorSecondary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@{viewModel.timestampString}"
                        android:textAppearance="@style/AppearanceFoundation.Body"
                        android:layout_marginBottom="@dimen/l1"
                        tools:text="1970-01-01 08:00:00" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Apk digest"
                        android:textSize="12sp"
                        android:textColor="?android:textColorSecondary" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@{viewModel.apkDigestString}"
                        android:textAppearance="@style/AppearanceFoundation.Body"
                        android:layout_marginBottom="@dimen/l2"
                        tools:text="CFMi+R9OC..." />

                    <Button
                        style="@style/WidgetFoundation.Button.Text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="View JSON"
                        android:textAllCaps="false"
                        android:textColor="?colorPrimary"
                        app:icon="@drawable/ic_show_md2"
                        app:iconTint="?colorPrimary" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <View
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <!-- Buttons -->
            <Button
                style="@style/WidgetFoundation.Button.Outlined"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/l1"
                android:onClick="@{() -> viewModel.reset()}"
                android:enabled="@{!viewModel.checking}"
                android:text="Run SafetyNet Attestation"
                android:textAllCaps="false"
                android:textColor="?colorPrimary"
                app:icon="@drawable/ic_refresh_safetynet_md2"
                app:iconTint="?colorPrimary" />

            <Button
                style="@style/WidgetFoundation.Button.Outlined"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/l2"
                android:text="Learn more"
                android:textAllCaps="false"
                android:textColor="?colorPrimary"
                app:icon="@drawable/ic_info"
                app:iconTint="?colorPrimary" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</layout>
