<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!--1st party themes-->

    <style name="ThemeFoundationMD2.Piplup">
        <!-- YASNAC dark: vivid blue accent works great on dark -->
        <item name="colorPrimary">#0A84FF</item>
        <item name="colorPrimaryVariant">#800A84FF</item>
        <item name="colorSecondary">#0066CC</item>
        <item name="colorSecondaryVariant">#800066CC</item>
        <!-- Dark card surfaces — like YASNAC dark mode -->
        <item name="colorSurface">#1C1C1E</item>
        <item name="colorSurfaceVariant">#2C2C2E</item>
        <item name="colorSurfaceSurfaceVariant">#2C2C2E</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="colorOnPrimaryVariant">#D9FFFFFF</item>
        <item name="colorOnSecondary">#FFFFFF</item>
        <item name="colorOnBackground">#F2F2F7</item>
        <item name="colorError">#FF453A</item>
        <item name="colorOnError">#FFFFFF</item>
        <item name="colorOnSurface">#F2F2F7</item>
        <item name="colorOnSurfaceVariant">#8E8E93</item>
        <item name="colorDisabled">#636366</item>
        <item name="colorDisabledVariant">#66636366</item>
    </style>

    <style name="ThemeFoundationMD2.Amoled" parent="ThemeFoundationMD2.Piplup">
        <item name="colorSurface">#000</item>
        <item name="colorOnPrimary">#FFF</item>
        <item name="colorOnSecondary">#FFF</item>
        <item name="colorOnBackground">#000</item>
        <item name="colorOnError">#FFF</item>
    </style>

    <style name="ThemeFoundationMD2.Zapdos" parent="ThemeFoundationMD2.Zapdos.Base">
        <item name="colorPrimary">#FBD179</item>
        <item name="colorPrimaryVariant">#80FBD179</item>
    </style>

    <style name="ThemeFoundationMD2.Mew" parent="ThemeFoundationMD2.Mew.Base">
        <item name="colorPrimary">#D9ADB7</item>
        <item name="colorPrimaryVariant">#80E9BBC5</item>
        <item name="colorOnPrimary">#000000</item>
        <item name="colorOnPrimaryVariant">#D9222222</item>
    </style>

    <!--3rd party themes-->

</resources>